generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  TRANSLATOR
  ADMIN
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs      Job[]
  history   History[]
  materials Material[]
}

model Job {
  id          String    @id @default(uuid())
  userId      String
  status      JobStatus @default(PENDING)
  sourceLang  String
  targetLang  String
  documentId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  document    Document? @relation(fields: [documentId], references: [id])
}

model Document {
  id           String   @id @default(uuid())
  originalName String
  storagePath  String
  sizeBytes    Int
  createdAt    DateTime @default(now())

  jobs         Job[]
}

model History {
  id           String   @id @default(uuid())
  userId       String
  type         String   // 'TEXT', 'DOCUMENT'
  details      String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
}

model Material {
  id           String   @id @default(uuid())
  userId       String
  title        String
  contentUrl   String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
}

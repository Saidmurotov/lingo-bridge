# Copy to .env and fill in. Never commit .env. (docs/07-DEPLOYMENT.md §1)

# --- App ---
NODE_ENV=development
API_PORT=3000
WEB_ORIGIN=http://localhost:5173

# --- Database ---
DB_USER=lingo
DB_PASSWORD=lingo
DB_NAME=lingobridge
DATABASE_URL="postgresql://lingo:lingo@localhost:5432/lingobridge?schema=public"

# --- Auth (generate: openssl rand -hex 32) ---
JWT_ACCESS_SECRET=CHANGE_ME_long_random
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# --- Anthropic (server-side only, never exposed to the frontend) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Redis (job queue) ---
REDIS_URL=redis://localhost:6379

# --- MinIO / S3 storage ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lingo-files
S3_REGION=us-east-1

# --- File policy ---
MAX_UPLOAD_MB=20
FILE_RETENTION_SOURCE_DAYS=30
FILE_RETENTION_RESULT_DAYS=90

# --- doc-worker ---
API_BASE_URL=http://localhost:3000/api
WORKER_TOKEN=CHANGE_ME_shared_secret_for_worker_callbacks
TESSERACT_LANGS=eng+rus+uzb

# --- Frontend (build-time; defaults to /api behind the dev proxy or Caddy) ---
# VITE_API_BASE_URL=/api

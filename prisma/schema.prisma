// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

 datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]
  materials Material[]
}

enum Role {
  CLIENT
  TRANSLATOR
  ADMIN
}

model Job {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  type        JobType
  status      JobStatus @default(QUEUED)
  inputPath   String   // MinIO key
  outputPath  String?  // MinIO key after processing
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum JobType {
  DOCUMENT_TRANSLATION
  QUICK_TRANSLATE
  MATERIAL_GENERATION
}

enum JobStatus {
  QUEUED
  IN_PROGRESS
  DONE
  REVIEW
  FAILED
}

model Material {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  topic       String
  level       String
  type        MaterialType
  contentPath String   // MinIO key
  createdAt   DateTime @default(now())
}

enum MaterialType {
  LESSON_PLAN
  EXERCISES
  PRESENTATION
}

# Local/dev: listens on :80. For prod replace :80 with the domain
# (e.g. lingobridge.uz) and Caddy will provision HTTPS automatically (docs/07 §3).
:80 {
    # API keeps its /api prefix — routes are mounted under /api in Fastify.
    handle /api/* {
        reverse_proxy api:3000
    }

    # Static SPA
    handle {
        reverse_proxy web:80
    }

    encode gzip zstd
}
